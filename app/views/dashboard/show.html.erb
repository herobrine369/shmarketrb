<!--app/views/dashboard/show.html.erb-->
<div class="container mx-auto p-8 max-w-6x1">
  <h1 class="text-4xl font-bold text-gray-900 mb-2">
    Welcome back, <%= current_user.username %>!
  </h1> <h2 class="te
<p class="text-gray-600 mb-10">
    Here's a quick overview of your marketplace activity.
  </p>
<!--Statistics Card-->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
    <div class="bg-white rounded-2x1 shadow p-6">
      <p class="text-sm text-gray-500">Total Listings</p>
      <p class="text-5xl font-bold text-gray-900 mt-2"><%= @total_listings %></p>
    </div>

    <div class="bg-white rounded-2x1 shadow p-6 border border-green-200">
      <p class="text-sm text-green-600">Active</p>
      <p class="text-5xl font-bold text-gray-600 mt-2"><%= @active_listings_count %></p>
    </div>

    <div class="bg-white rounded-2x1 shadow p-6 border border-orange-200">
      <p class="text-sm text-orange-600">Reservd</p>
      <p class="text-5xl font-bold text-gray-900 mt-2"><%= @reserved_count %></p>
    </div>

    <div class="bg-white rounded-2x1 shadow p-6 border border-red-200">
      <p class="text-sm text-red-600">Sold</p>
      <p class="text-5xl font-bold text-red-600 mt-2"><%= @sold_count %></p>
    </div>
<div>

<!--Recent Listings-->
<h2 class="text-2xl font-semibold mb-6">My Recent Listings</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% if @recent_listings.any? %>
        <% @recent_listings.each do |product| %>
          <div class="bg-white border border-gray-200 rounded-2x1 p-5 hover:shadow-md transition">
            <div class="flex justify-between items-starts">
              <h3 class="front-medium text-lg"><%= product.name %></h3>
              <span class="px-3 py-1 text-xs font-medium rounded-full"
                    <%= product.state == 'available' ? 'bg-green-100 text-green-700' :
                        product.state == 'reserved' ? 'bg-orange-100 text-orange-700' :
                        'bg-red-100 text-red-700' %>>
                <%= product.state.capitalize %>
                </span>
            </div>
            <p class="text-3x1 font-bold text-gray-900 mt-4">HK$<%= product.price %></p>
            <p class="text-sm text-gray-500 mt-1">Posted<%= product.post_date.strftime("%b %d, %Y") %></p>
        </div>
    <% end %>
<% else %>
    <p class="text-gray-500 italic">You haven't post any items yet.</p>
<% end %>
</div>

<!--Quick Actions-->
<div class="flex gap-4 mt-12">
    <%= link_to "Post New Item", new_product_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-2x1 font-medium text-lg flex-1 text-center" %>

    <%= link_to "View All my Listings", profile_path, class: "border border-gray-300 hover:bg-gray-50 px-8 py-4 rounded-2x1 font-medium text-lg flex-1 text-center" %>
</div>
</div>