<% content_for :title, "Admin | Edit #{@product.name}" %>

<div class="w-full space-y-6">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Edit Product (Admin)</h1>
      <p class="text-sm text-slate-600">Modify product details on behalf of the seller.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Cancel", admin_product_path(@product), class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
    </div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_with model: [:admin, @product], class: "space-y-5" do |form| %>
      <% if @product.errors.any? %>
        <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">
          <ul class="list-disc ml-4 space-y-1">
            <% @product.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.text_field :name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
      </div>

      <div>
        <%= form.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.text_area :description, rows: 4, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :category, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.select :category,
                options_for_select([
                  ["Furniture", "furniture"], ["Books", "books"], ["Clothes", "clothes"],
                  ["Electrical Appliances", "electrical appliances"], ["Tickets", "tickets"],
                  ["Service", "service"], ["Sports Gear", "sports gear"], ["Others", "others"]
                ], @product.category),
                { prompt: "Select a category" },
                class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
        </div>

        <div>
          <%= form.label :condition, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.select :condition,
                options_for_select([
                  ["Brand New", "brand new"], ["Used", "used"], ["N/A", "N/A"]
                ], @product.condition),
                { prompt: "Select a condition" },
                class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
        </div>

        <div>
          <%= form.label :state, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.select :state,
                options_for_select(Product::STATES.map { |s| [s.titleize, s] }, @product.state),
                {},
                class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
        </div>

        <div>
          <%= form.label :price, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <div class="flex items-center gap-2">
            <span class="text-sm text-slate-500">HK$</span>
            <%= form.number_field :price, step: :any, min: 0, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <%= form.submit "Save Changes", class: "rounded-lg bg-sky-600 px-5 py-2 text-sm font-semibold text-white hover:bg-sky-500" %>
        <%= link_to "Cancel", admin_product_path(@product), class: "rounded-lg border border-slate-300 px-5 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>
</div>
