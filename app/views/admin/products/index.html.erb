<% content_for :title, "Admin | Product Management" %>

<div class="w-full space-y-6">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Admin Product Management</h1>
      <p class="text-sm text-slate-600">Review listings, filter data, and update product status.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Dashboard", admin_dashboard_path, class: "inline-flex items-center justify-center rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
      <%= link_to "Back to Marketplace", products_path, class: "inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
    </div>
  </div>

  <%= form_with url: admin_products_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm md:grid-cols-6" do |form| %>
    <div class="md:col-span-2">
      <%= form.label :query, "Search", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :query, value: @query, placeholder: "name / category / description", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div>
      <%= form.label :state, "State", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :state, options_for_select([["All", ""]] + @state_options.map { |item| [item.titleize, item] }, @state), {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div>
      <%= form.label :category, "Category", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :category, options_for_select([["All", ""]] + @category_options, @category), {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div>
      <%= form.label :sort, "Sort by", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :sort, options_for_select([["Newest", "newest"], ["Oldest", "oldest"], ["Price: Low to High", "price_low"], ["Price: High to Low", "price_high"], ["State", "state"]], @sort), {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div>
      <%= form.label :min_price, "Min price", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.number_field :min_price, value: @min_price, step: :any, min: 0, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div>
      <%= form.label :max_price, "Max price", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.number_field :max_price, value: @max_price, step: :any, min: 0, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div class="md:col-span-6 flex flex-wrap items-center gap-2">
      <%= form.submit "Apply Filters", class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500" %>
      <%= link_to "Reset", admin_products_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      <span class="text-xs text-slate-500"><%= @total_count %> result(s), page <%= @page %> / <%= @total_pages %></span>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Category</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Price</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">State</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Posted</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white text-sm text-slate-700">
          <% if @products.any? %>
            <% @products.each do |product| %>
              <tr class="align-top">
                <td class="px-4 py-3">
                  <p class="font-semibold text-slate-900"><%= product.name %></p>
                  <p class="mt-1 max-w-xs text-xs text-slate-500"><%= truncate(product.description, length: 80) %></p>
                </td>
                <td class="px-4 py-3"><%= product.category.titleize %></td>
                <td class="px-4 py-3">HK$ <%= product.price %></td>
                <td class="px-4 py-3">
                  <% badge_class = case product.state
                                  when "available" then "bg-emerald-100 text-emerald-700"
                                  when "reserved" then "bg-amber-100 text-amber-700"
                                  else "bg-slate-200 text-slate-700"
                                  end %>
                  <span class="rounded-full px-2.5 py-1 text-xs font-semibold <%= badge_class %>"><%= product.state.titleize %></span>
                </td>
                <td class="px-4 py-3"><%= product.post_date %></td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <% Product::STATES.each do |state| %>
                      <%= button_to state.titleize, update_status_admin_product_path(product, state: state, query: @query, category: @category, min_price: @min_price, max_price: @max_price, sort: @sort, page: @page), method: :patch, class: "rounded-md border px-2.5 py-1 text-xs font-medium #{state == product.state ? "border-sky-300 bg-sky-100 text-sky-700" : "border-slate-300 bg-white text-slate-700 hover:bg-slate-50"}" %>
                    <% end %>
                    <%= link_to "Admin View", admin_product_path(product), class: "rounded-md bg-slate-900 px-2.5 py-1 text-xs font-medium text-white hover:bg-slate-700" %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-4 py-8 text-center text-sm text-slate-500">No products found with current filters.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @total_pages > 1 %>
    <div class="flex items-center justify-end gap-2">
      <% previous_page = @page - 1 %>
      <% next_page = @page + 1 %>
      <% previous_params = { query: @query, state: @state, category: @category, min_price: @min_price, max_price: @max_price, sort: @sort, page: previous_page } %>
      <% next_params = { query: @query, state: @state, category: @category, min_price: @min_price, max_price: @max_price, sort: @sort, page: next_page } %>
      <% if @page > 1 %>
        <%= link_to "Previous", admin_products_path(previous_params), class: "rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
      <% end %>
      <% if @page < @total_pages %>
        <%= link_to "Next", admin_products_path(next_params), class: "rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
      <% end %>
    </div>
  <% end %>
</div>
