<!-- app/views/profiles/edit.html.erb -->
<div class="max-w-[1600px] mx-auto mt-10 bg-white rounded-3xl shadow-xl p-10">
  <div class="flex justify-between items-center mb-10">
    <%= link_to "←", profile_path, class: "text-blue-600 hover:text-blue-700 font-medium flex items-center gap-1 text-lg" %>
    <h1 class="text-4xl font-bold">Edit Profile</h1>
  </div>

  <%= form_with model: @user, url: profile_path, method: :put, multipart: true do |f| %>

    <!-- Profile Photo -->
    <div class="mb-10">
      <label class="block text-sm font-medium text-gray-700 mb-3">Profile Photo</label>
      <%= f.file_field :avatar, class: "block w-full text-sm text-gray-500 
                     file:mr-4 file:py-4 file:px-8 file:rounded-2xl 
                     file:border-0 file:text-sm file:font-medium 
                     file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      <p class="text-xs text-gray-500 mt-2">Recommended: 400×400 px (JPG or PNG)</p>
    </div>

    <!-- Username -->
    <div class="mb-8">
      <%= f.label :username, "Username", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :username, class: "w-full px-6 py-5 border border-gray-300 rounded-2xl text-lg focus:outline-none focus:border-blue-500" %>
    </div>

    <!-- College Dropdown -->
    <div class="mb-10">
      <%= f.label :college, "College", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :college, 
                   ["Chung Chi College", "New Asia College", "United College", 
                    "Shaw College", "Morningside College", "S.H. Ho College", 
                    "CW Chu College", "Wu Yee Sun College", "Lee Woo Sing College"], 
                   { prompt: "Select your college" }, 
                   class: "w-full px-6 py-5 border border-gray-300 rounded-2xl text-lg focus:outline-none focus:border-blue-500" %>
    </div>

    <!-- Bio / Self Introduction -->
<div class="mb-10">
  <%= f.label :bio, "Bio / Self Introduction", class: "block text-sm font-medium text-gray-700 mb-2" %>
  <%= f.text_area :bio, 
       rows: 6,
       class: "w-full px-6 py-5 border border-gray-300 rounded-2xl text-lg focus:outline-none focus:border-blue-500 resize-y",
       placeholder: "Tell us about yourself..." %>
  <p class="text-xs text-gray-500 mt-2">Max 500 characters recommended (new lines are preserved)</p>
</div>

    <!-- Buttons -->
    <div class="flex gap-4">
      <%= f.submit "Save Changes", 
                   class: "flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-5 rounded-2xl text-xl cursor-pointer transition" %>

      <%= link_to "Cancel", profile_path, 
                  class: "flex-1 border border-gray-300 hover:bg-gray-50 font-semibold py-5 rounded-2xl text-xl text-center transition" %>
    </div>

  <% end %>
</div>