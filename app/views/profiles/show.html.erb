<div class="container mx-auto p-8 max-w-4x1">
  <h1 class="text-4xl font-bold mb-8">
    My Profile
  </h1>

  <div class="bg-white rounded-3x1 shadow-lg p-10">
    <div >
        <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "w-32 h-32 rounded-2x1 object-cover" %>
        <% else %>
            <div class="w-32 h-32 bg-gray-200 rounded-2x1 flex items-center justify-center">👤</div>
        <% end %>
    </div>
    <div class="flex-1">
       <p class="text-3xl font-semibold"><%= @user.username %></p>
       <p class="text-xl text-gray-600">College: <%= @user.college %></p>
       <p class="text-sm text-gray-500">Member since <%= @user.created_at.strftime("%B %Y") %></p>

       <%= link_to "Edit Profile", edit_profile_path, class: "mt-6 inline-block bg-blue-600 text-white px-8 py-4 rounded-2xl font-medium" %>
    </div>
  </div>
</div>