<body class="bg-white min-h-screen md:p-10">
  <div class="mx-auto max-w-md w-full bg-white shadow-xl rounded-2xl p-8 border border-gray-100">

    <!-- Header – already centered -->
    <div class="text-center mb-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
        Log in to your account
      </h2>
      <p class="mt-3 text-sm text-gray-600">
        Don't have an account yet?
        <%= link_to "Sign up", new_registration_path(resource_name),
                    class: "font-medium text-indigo-600 hover:text-indigo-500 hover:underline" %>
      </p>
    </div>

    <!-- Form – centered children -->
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-6") do |f| %>

      <div class="space-y-5">
        <!-- Email -->
        <div class="text-left"> <!-- keep labels left-aligned for better readability -->
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
                            autofocus: true,
                            autocomplete: "email",
                            class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
        </div>

        <!-- Password -->
        <div class="text-left">
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password,
                               autocomplete: "current-password",
                               class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
        </div>

        <!-- Remember me + Forgot password – centered row -->
        <div class="flex items-center justify-left py-4 flex-wrap gap-6 text-sm">
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
              <%= f.label :remember_me, class: "ml-2 text-gray-700 select-none" %>
            </div>
          <% end %>

         <%#  <%= link_to "Forgot your password?", new_password_path(resource_name),
                      class: "text-indigo-600 hover:text-indigo-500 hover:underline" %>
        </div>
      </div>

      <!-- Submit button – full width & centered by default -->
      <div>
        <%= f.submit "Log in",
                     class: "w-full py-3 px-4 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition shadow-md" %>
      </div>

    <% end %>

    <!-- Extra links – centered -->
    <div class="mt-6 text-center text-sm text-indigo-600">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</body>




