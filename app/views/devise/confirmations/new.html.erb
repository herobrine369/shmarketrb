<body class="bg-white min-h-screen md:p-10">
<div class="mx-auto max-w-md w-full bg-white shadow-xl rounded-2xl p-8 border border-gray-100">

  <!-- Header – centered -->
  <div class="text-center mb-8">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
      Resend confirmation instructions
    </h2>
    <p class="mt-3 text-sm text-gray-600">
      No worries! Enter your email address and we’ll resend the confirmation instructions.
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }, class: "space-y-6") do |f| %>

    <!-- Error messages -->
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5">

      <!-- Email -->
      <div class="text-left -mt-2"> <!-- tight spacing after header (matches your forgot-password & edit styles) -->
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                          class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

    </div>

    <!-- Submit button – full width -->
    <div>
      <%= f.submit "Resend confirmation instructions",
                   class: "w-full py-3 px-4 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition shadow-md" %>
    </div>

  <% end %>

  <!-- Extra links – centered -->
  <div class="mt-6 text-center text-sm text-indigo-600">
    <%= render "devise/shared/links" %>
  </div>

</div>
</body>

