<body class="bg-white min-h-screen md:p-10">
<div class="mx-auto max-w-md w-full bg-white shadow-xl rounded-2xl p-8 border border-gray-100">

  <!-- Header – already centered -->
  <div class="text-center mb-8">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
      Create your account
    </h2>
    <p class="mt-3 text-sm text-gray-600">
      Already have an account?
      <%= link_to "Log in", new_session_path(resource_name),
                  class: "font-medium text-indigo-600 hover:text-indigo-500 hover:underline" %>
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-6") do |f| %>

    <!-- Error messages (Devise shared partial) -->
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5">

      <!-- Email -->
      <div class="text-left">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

      <!-- username-->
      <div class="text-left">
          <%= f.label :username, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
     </div>

     <!-- college-->
      <div class="text-left">
        <%= f.label :college, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :college, options_for_select([
                       "Chung Chi College",
                       "New Asia College",
                       "United College",
                       "Shaw College",
                       "C.W.Chu College",
                       "S.H.Ho College",
                       "The Sunny College",
                       "Lee Woo Sing College",
                       "Morningside College"
                     ], selected: f.object.college),
                     { prompt: "Select your college..." },
                     class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 h-11 text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

      <!-- Password -->
      <div class="text-left">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mt-1">
            (<%= @minimum_password_length %> characters minimum)
          </p>
        <% end %>
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

      <!-- Password confirmation -->
      <div class="text-left pb-4">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

    </div>

    <!-- Submit button – full width -->
    <div>
      <%= f.submit "Sign up",
                   class: "w-full py-3 px-4 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition shadow-md" %>
    </div>

  <% end %>

  <!-- Extra links – centered -->
  <div class="mt-6 text-center text-sm text-indigo-600">
    <%= render "devise/shared/links" %>
  </div>

</div>
</body>




