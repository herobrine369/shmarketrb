<body class="bg-white min-h-screen md:p-10">
<div class="mx-auto max-w-md w-full bg-white shadow-xl rounded-2xl p-8 border border-gray-100">

  <!-- Header – centered -->
  <div class="text-center mb-8">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
      Edit your account
    </h2>
    <p class="mt-3 text-sm text-gray-600">
      Update your email or password below.
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }, class: "space-y-6") do |f| %>

    <!-- Error messages -->
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5">

      <!-- Email -->
      <div class="text-left -mt-2">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="text-sm bg-amber-50 border border-amber-200 rounded-lg p-4 text-amber-800">
          Currently waiting confirmation for: <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <!-- New password (optional) -->
      <div class="text-left">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mt-1">(leave blank if you don't want to change it)</p>
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mt-1">
            (<%= @minimum_password_length %> characters minimum)
          </p>
        <% end %>
      </div>

      <!-- Password confirmation -->
      <div class="text-left">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

      <!-- Current password -->
      <div class="text-left pb-4">
        <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-500 mt-1">(we need your current password to confirm your changes)</p>
        <%= f.password_field :current_password,
                             autocomplete: "current-password",
                             class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 sm:text-sm transition" %>
      </div>

    </div>

    <!-- Submit button – full width -->
    <div>
      <%= f.submit "Update",
                   class: "w-full py-3 px-4 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition shadow-md" %>
    </div>

  <% end %>

  <!-- Cancel account – danger zone -->
  <div class="mt-8 pt-8 border-t border-gray-200">
    <h3 class="text-lg font-semibold text-red-700 mb-2">Cancel my account</h3>
    <p class="text-sm text-gray-600 mb-4">
      Unhappy? You can delete your account permanently.
    </p>
    <%= button_to "Cancel my account",
                  registration_path(resource_name),
                  method: :delete,
                  data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                  class: "w-full py-3 px-4 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition shadow-md" %>
  </div>

  <!-- Back link – centered -->
  <div class="mt-6 text-center text-sm">
    <%= link_to "Back", :back,
                class: "font-medium text-indigo-600 hover:text-indigo-500 hover:underline" %>
  </div>

</div>
</body>


