<!-- to display image-->
<% if product.image.attached? %>
  <div class="mb-4">
    <%= image_tag product.image, class: "w-full h-48 object-cover rounded-xl", alt: product.name %>
  </div>
<% else %>
<!-- if there's no image, put placeholder-->
  <div class="mb-4 w-full h-48 bg-gray-200 rounded-xl flex items-center justify-center text-gray-400">
    No image
  </div>
<% end %>
<!-- for product info-->
<div id="<%= dom_id product %>" class="w-full sm:w-auto my-5 space-y-5">
  <h3 class="font-semibold text-xl leading-tight mb-0.5 line-clamp-2">
    <%= product.name %>
  </h3>
  <p class="text-2xl font-bold tracking-tighter text-gray-900 mb-0.5">
    HK$ <%= number_with_delimiter(product.price) %>
  </p>
  <p class="text-sm text-gray-500 font-medium mb-0.5">
    <%= product.condition %>
  </p>
  <p class="text-sm text-gray-500 font-medium">
    <%= product.category %>
  </p>
  <div class="flex justify-between text-sm text-gray-500 font-medium mt-3">
    <span><%= product.user.username %></span>
    <span><%= product.user.college %></span>
  </div>
</div>
