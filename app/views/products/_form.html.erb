<%= form_with(model: product, class: "contents") do |form| %>
  <% if product.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul class="list-disc ml-6">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :image, "Product image" %>
    <%= form.file_field :image, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
  </div>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:name].none?, "border-red-400 focus:outline-red-600": product.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_field :description, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:description].none?, "border-red-400 focus:outline-red-600": product.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :category %>
    <%= form.select :category, options_for_select([["Furniture", "furniture"], ["Books", "books"], ["Clothes", "clothes"], ["Electrical appliances", "electrical appliances"], ["Tickets", "tickets",],
    ["Service", "service"], ["Sports gear", "sports gear"], ["Others", "others"]]),
    { prompt: "Select a Category"},
    class: ["block shadow-sm rounded-md border px-3 py-4 mt-2 w-full h-11", {"border-gray-400 focus:outline-blue-600": product.errors[:category].none?, "border-red-400 focus:outline-red-600": product.errors[:category].any?}] 
    %>
    <!-- form.text_field :category, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:category].none?, "border-red-400 focus:outline-red-600": product.errors[:category].any?}] -->
  </div>

  <div class="my-5">
  <%= form.label :state %>
  <!-- to create a drop down menu-->
  <!--options_for_select to create dropdown ooptinos -->
  <!--prmopt to show hint before any states is picked -->
  <%= form.select :state,
                  options_for_select( 
                    [["Available", "available"],["Reserved", "reserved"], ["Sold", "sold"]],product.state
                  ),
                  { prompt: "Select a state" },
                  class: ["block shadow-sm rounded-md border px-3 py-4 mt-2 w-full h-11",
                          {"border-gray-400 focus:outline-blue-600": product.errors[:state].none?,
                           "border-red-400 focus:outline-red-600": product.errors[:state].any?}] %>
</div>

  <div class="my-5">
    <%= form.label :condition %>
    <%= form.select :condition, options_for_select([["Brand new", "brand new"], ["Used", "used"], ["N/A", "N/A"]]),
    { prompt: "Select a Condition"},
    class: ["block shadow-sm rounded-md border px-3 py-4 mt-2 w-full h-11", {"border-gray-400 focus:outline-blue-600": product.errors[:condition].none?, "border-red-400 focus:outline-red-600": product.errors[:condition].any?}] 
    %>
    <!-- form.text_field :condition, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:condition].none?, "border-red-400 focus:outline-red-600": product.errors[:condition].any?}] -->
  </div>

  <div class="my-5">
    <%= form.label :price %>
    <%= form.text_field :price, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:price].none?, "border-red-400 focus:outline-red-600": product.errors[:price].any?}] %>
  </div>

  <!-- class="my-5">
    <%= form.label :post_date %>
    <%= form.date_field :post_date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": product.errors[:post_date].none?, "border-red-400 focus:outline-red-600": product.errors[:post_date].any?}] %>
  -->

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
