<% content_for :title, "Product" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h2 class="font-bold text-4xl">Broswe Everything go go goooo~~</h2>
    <%= link_to "New product", new_product_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>
  
<!-- search-->
<div class="mt-8 mb-6">
    <%= form_with url: products_path, method: :get, class: "flex gap-3" do |form| %>
      <div class="flex-1 relative">
        <%= form.text_field :search, placeholder: "Search whatever you like", value: params[:search], class: "block w-full rounded-2xl border border-gray-300 px-5 py-3 text-base focus:border-blue-600 focus:ring-blue-600" %>
      </div>
      <%= form.submit "Search", class: "px-8 rounded-2xl bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
    <% end %>
</div>

<!-- add a list of category to select -->
<div class="flex flex-wrap gap-2 mt-8 mb-6">
  <%= link_to "All", products_path, class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Furniture", products_path(category: "furniture"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'furniture' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Electrical appliances", products_path(category: "electrical appliance"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'electronics' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Books", products_path(category: "books"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'books' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Clothes", products_path(category: "clothes"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'clothes' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Tickets", products_path(category: "tickets"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'tickets' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Service", products_path(category: "service"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'service' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Sports gear", products_path(category: "sports gear"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'sports gear' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
  <%= link_to "Others", products_path(category: "others"), class: "px-5 py-2.5 rounded-2xl font-medium text-sm #{params[:category] == 'others' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}" %>
</div>

<!-- product page-->
  <div id="products" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mt-8">

    <% if @products.any? %>
      <% @products.each do |product| %>
        <div class="bg-white border border-gray-200 rounded-2xl overflowhidden shadow-sm hover:shadow-md transition-all duration-200 flex flex-col">

          <div class = "p-6">
            <%= render "product_page", product: product %>
          </div>
          <div class="p-4 mt-auto flex flex-wrap gap-2 border-t border-gray-100">
            <%= link_to "Show", product, class: "flex-1 text-center rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 font-medium" %>
            <%= link_to "Edit", edit_product_path(product), class: "flex-1 text-center rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 font-medium" %>
            <%= button_to "Destroy", product, method: :delete, class: "flex-1 rounded-lg px-4 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>

    <% else %>
      <p class="text-center my-10 col-span-full">No products found.</p>
    <% end %>

  </div>
</div>